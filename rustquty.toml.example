# rustquty.toml - Example configuration
# Copy to your Rust project root and customize

[profile]
# Default quality scan profile: fast | full | deep
# fast = fmt + clippy only
# full = all collectors except mutants (default)
# deep = all collectors including mutation testing
default = "full"

[collectors]
# Disable specific collectors globally
# mutants = false
# hack = false

[gate]
# Override baseline thresholds at check time
[gate.coverage]
min_line_percent = 80.0

[gate.size]
# Maximum total lines per file (optional, omit to skip this rule)
max_lines_per_file = 1000
# Maximum code lines per file (non-comment, non-blank lines)
max_code_lines_per_file = 700
# Maximum lines per function
max_lines_per_function = 80
# Maximum parameters per function
max_parameters_per_function = 6

# Absolute thresholds based on industry standards (SonarQube, ESLint, DeepSource).
# When set, these override the ratchet baseline for the specified metric.
# Omit any field to use the baseline value instead.
[gate.defaults]
# SonarQube default: 15, DeepSource/Detekt default: 10
max-cyclomatic-per-function = 15
# ESLint default: 4, Detekt/ReSharper default: 5
max-nesting-depth = 5
# SonarQube default: 80, ESLint: 50, Detekt: 60
max-lines-per-function = 80
# SonarQube default: 1000
max-lines-per-file = 1000
# Maximum code lines per file (non-comment, non-blank)
max-code-lines-per-file = 700
# SonarQube default: 7, Detekt: 6, ESLint: 3
max-parameters-per-function = 7
# SonarQube default: 80.0%
min-coverage-percent = 80.0
# SonarQube default: 3% of new code (set as absolute line count)
# max-duplicate-lines = 100
# Maximum clippy warnings (0 = no warnings allowed)
max-clippy-warnings = 0
# ESLint default: 80, rustfmt default: 120
max-line-length = 120

[output]
# Override default quality/ output directory
# dir = "quality"
